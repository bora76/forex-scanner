//@version=6
indicator("Forex Majors Scanner — Trend / Gegentrend", overlay = true, max_bars_back = 200)

// ════════════════════════════════════════════════
//  EINSTELLUNGEN
// ════════════════════════════════════════════════

// --- Datenquelle / Broker ---
broker = input.string("SWISSQUOTE", "Broker / Datenquelle",
     options = ["SWISSQUOTE", "SAXO", "IBKR", "OANDA", "FX", "FXCM"],
     group = "Datenquelle")

// --- MACD ---
macdFast    = input.int(12, "MACD schnell", minval = 1, group = "MACD")
macdSlow    = input.int(26, "MACD langsam", minval = 1, group = "MACD")
macdSigLen  = input.int(9,  "MACD Signal",  minval = 1, group = "MACD")
macdSigType = input.string("SMA", "MACD Signaltyp", options = ["SMA", "EMA"], group = "MACD")

// --- Bollinger Bänder ---
bbLength = input.int(12,   "BB Länge",  minval = 1,   group = "Bollinger Bänder")
bbMult   = input.float(2.0,"BB StdDev", minval = 0.1, step = 0.1, group = "Bollinger Bänder")

// --- Darstellung ---
showBands  = input.bool(true, "Bollinger Bänder zeichnen", group = "Darstellung")
showArrows = input.bool(true, "Pfeile bei Schlusskurs außerhalb der Bänder", group = "Darstellung")

// --- Symbole (leeres Feld = Slot deaktiviert) ---
gSym = "Symbole  (nur Paar ohne Broker, z.B. EURUSD — leeres Feld = deaktiviert)"
p01 = input.string("EURUSD", "Paar 01", group = gSym)
p02 = input.string("GBPUSD", "Paar 02", group = gSym)
p03 = input.string("USDJPY", "Paar 03", group = gSym)
p04 = input.string("USDCHF", "Paar 04", group = gSym)
p05 = input.string("USDCAD", "Paar 05", group = gSym)
p06 = input.string("AUDUSD", "Paar 06", group = gSym)
p07 = input.string("NZDUSD", "Paar 07", group = gSym)
p08 = input.string("EURGBP", "Paar 08", group = gSym)
p09 = input.string("EURJPY", "Paar 09", group = gSym)
p10 = input.string("EURCHF", "Paar 10", group = gSym)
p11 = input.string("EURCAD", "Paar 11", group = gSym)
p12 = input.string("EURAUD", "Paar 12", group = gSym)
p13 = input.string("EURNZD", "Paar 13", group = gSym)
p14 = input.string("GBPJPY", "Paar 14", group = gSym)
p15 = input.string("GBPCHF", "Paar 15", group = gSym)
p16 = input.string("GBPCAD", "Paar 16", group = gSym)
p17 = input.string("GBPAUD", "Paar 17", group = gSym)
p18 = input.string("GBPNZD", "Paar 18", group = gSym)
p19 = input.string("CHFJPY", "Paar 19", group = gSym)
p20 = input.string("CADJPY", "Paar 20", group = gSym)
p21 = input.string("AUDJPY", "Paar 21", group = gSym)
p22 = input.string("NZDJPY", "Paar 22", group = gSym)
p23 = input.string("CADCHF", "Paar 23", group = gSym)
p24 = input.string("AUDCHF", "Paar 24", group = gSym)
p25 = input.string("NZDCHF", "Paar 25", group = gSym)
p26 = input.string("AUDCAD", "Paar 26", group = gSym)
p27 = input.string("NZDCAD", "Paar 27", group = gSym)
p28 = input.string("AUDNZD", "Paar 28", group = gSym)

// ════════════════════════════════════════════════
//  INDIKATOR-HELPER  (kontextneutral: laufen im aufrufenden Symbol/TF)
// ════════════════════════════════════════════════
f_macd() =>
    macdLine   = ta.ema(close, macdFast) - ta.ema(close, macdSlow)
    signalLine = macdSigType == "EMA" ? ta.ema(macdLine, macdSigLen) : ta.sma(macdLine, macdSigLen)
    [macdLine, signalLine]

f_bb() =>
    basis = ta.sma(close, bbLength)
    dev   = bbMult * ta.stdev(close, bbLength)
    [basis + dev, basis, basis - dev]

// ════════════════════════════════════════════════
//  BERECHNUNG  (läuft im Kontext des jeweiligen Symbols)
//  Gibt für die LETZTE ABGESCHLOSSENE Kerze zurück: [gegentrend, trend]
// ════════════════════════════════════════════════
f_scan() =>
    [macdLine, signalLine] = f_macd()
    [upper, _basis, lower] = f_bb()

    // Hintergrund-Klassifikation pro Kerze
    isGreen   = macdLine > 0 and macdLine > signalLine
    isRed     = macdLine < 0 and macdLine < signalLine
    isColored = isGreen or isRed
    isNeutral = not isColored

    // Schlusskurs ausserhalb der Bollinger Bänder?
    outside = close > upper or close < lower

    // Dynamischer Offset, um IMMER auf die letzte ABGESCHLOSSENE Tageskerze
    // zu schauen — unabhängig davon, ob der Markt gerade offen ist:
    //   - Markt offen (heutige Bar formt sich noch): off = 1 → gestern
    //   - Markt zu  (heutige Bar ist bereits final, z.B. Wochenende): off = 0 → "heute"
    int off = time_close <= timenow ? 0 : 1

    // Gegentrend-Kerze: neutral, ODER erste farbige Kerze nach einer Neutral-Phase
    gegentrendCandle = isNeutral[off] or (isColored[off] and isNeutral[off + 1])
    trendCandle      = isColored[off]

    gegentrend = outside[off]       and gegentrendCandle
    trend      = (not outside[off]) and trendCandle

    [gegentrend, trend]

// ════════════════════════════════════════════════
//  SCAN ALLER SLOTS
// ════════════════════════════════════════════════
var string[] gegenList = array.new_string()
var string[] trendList = array.new_string()
array.clear(gegenList)
array.clear(trendList)

handle(simple string pair) =>
    valid = str.length(pair) > 0
    sym   = valid ? broker + ":" + pair : broker + ":EURUSD"   // Dummy für leere Slots
    [g, t] = request.security(sym, "D", f_scan())
    if valid and barstate.islast
        if g
            array.push(gegenList, pair)
        if t
            array.push(trendList, pair)

handle(p01)
handle(p02)
handle(p03)
handle(p04)
handle(p05)
handle(p06)
handle(p07)
handle(p08)
handle(p09)
handle(p10)
handle(p11)
handle(p12)
handle(p13)
handle(p14)
handle(p15)
handle(p16)
handle(p17)
handle(p18)
handle(p19)
handle(p20)
handle(p21)
handle(p22)
handle(p23)
handle(p24)
handle(p25)
handle(p26)
handle(p27)
handle(p28)

// ════════════════════════════════════════════════
//  BOLLINGER BÄNDER  (aktuelles Chart-Symbol)
// ════════════════════════════════════════════════
[bbUpper, bbBasis, bbLower] = f_bb()

// Bänder nur bis zur letzten abgeschlossenen Kerze zeichnen — die aktuell
// formende Bar bekommt na, damit der Plot dort endet.
barClosed = time_close <= timenow
pUpper = plot(showBands and barClosed ? bbUpper : na, "BB Oben",  color = color.new(color.blue, 0))
pBasis = plot(showBands and barClosed ? bbBasis : na, "BB Basis", color = color.new(color.blue, 50))
pLower = plot(showBands and barClosed ? bbLower : na, "BB Unten", color = color.new(color.blue, 0))
fill(pUpper, pLower, color = showBands ? color.new(color.blue, 92) : na, title = "BB Fläche")

// ════════════════════════════════════════════════
//  PFEILE  —  Schlusskurs außerhalb der Bänder
//  Standardprüfung auf [1]: markiert jede Bar während der Iteration der
//  nächsten Bar (Bar N bekommt seinen Pfeil bei Bar N+1).
// ════════════════════════════════════════════════
closeAbove = close[1] > bbUpper[1]
closeBelow = close[1] < bbLower[1]

if showArrows and closeAbove
    label.new(bar_index[1], high[1], text = "↑", style = label.style_none,
         textcolor = color.green, size = size.normal, yloc = yloc.abovebar)

if showArrows and closeBelow
    label.new(bar_index[1], low[1], text = "↓", style = label.style_none,
         textcolor = color.red, size = size.normal, yloc = yloc.belowbar)

// Sonderfall: letzte Bar der Serie hat bereits geschlossen (z.B. Wochenende).
// Dann muss sie direkt markiert werden, ohne auf eine nächste Bar zu warten.
// var-Labels + delete vermeiden Duplikate bei Re-Ticks.
var label lastBarUp = na
var label lastBarDn = na

if barstate.islast
    label.delete(lastBarUp)
    label.delete(lastBarDn)
    if showArrows and time_close <= timenow
        if close > bbUpper
            lastBarUp := label.new(bar_index, high, text = "↑", style = label.style_none,
                 textcolor = color.green, size = size.normal, yloc = yloc.abovebar)
        if close < bbLower
            lastBarDn := label.new(bar_index, low, text = "↓", style = label.style_none,
                 textcolor = color.red, size = size.normal, yloc = yloc.belowbar)

// ════════════════════════════════════════════════
//  CHART-HINTERGRUND  (aktuelles Chart-Symbol)
// ════════════════════════════════════════════════
[cMacd, cSig] = f_macd()
chartGreen = cMacd > 0 and cMacd > cSig
chartRed   = cMacd < 0 and cMacd < cSig
bgcolor(chartGreen ? color.new(color.green, 88) : chartRed ? color.new(color.red, 88) : na, title = "Hintergrund Trendrichtung")

// ════════════════════════════════════════════════
//  TABELLE
// ════════════════════════════════════════════════
var table tbl = table.new(position.top_right, 2, 1, border_width = 1, border_color = color.new(color.gray, 50))

// Markiert das aktuelle Chart-Symbol — aber nur, wenn der Chart-Broker
// dem in den Settings ausgewählten Broker entspricht. Padding mit 2 Zeichen
// hält die Symbole in Monospace-Schrift bündig.
chartSym    = syminfo.ticker
brokerMatch = syminfo.prefix == broker

f_mark(string s) =>
    isPair    = s != "" and s != "—"
    isCurrent = brokerMatch and s == chartSym
    isPair ? (isCurrent ? "▶ " + s : "  " + s) : s

if barstate.islast
    gsz = array.size(gegenList)
    tsz = array.size(trendList)
    dataRows = math.max(math.max(gsz, tsz), 1)
    rows = dataRows + 1

    table.delete(tbl)
    tbl := table.new(position.top_right, 2, rows, border_width = 1, border_color = color.new(color.gray, 50))

    table.cell(tbl, 0, 0, "GEGENTREND (" + str.tostring(gsz) + ")", text_color = color.white, bgcolor = color.new(#7b1fa2, 0))
    table.cell(tbl, 1, 0, "TREND (" + str.tostring(tsz) + ")",      text_color = color.white, bgcolor = color.new(#1565c0, 0))

    for r = 1 to dataRows
        gi   = r - 1
        gtxt = gi < gsz ? array.get(gegenList, gi) : (gi == 0 and gsz == 0 ? "—" : "")
        ttxt = gi < tsz ? array.get(trendList, gi) : (gi == 0 and tsz == 0 ? "—" : "")
        table.cell(tbl, 0, r, f_mark(gtxt), text_color = color.white, bgcolor = (gtxt == "" or gtxt == "—") ? na : color.new(#7b1fa2, 75), text_font_family = font.family_monospace)
        table.cell(tbl, 1, r, f_mark(ttxt), text_color = color.white, bgcolor = (ttxt == "" or ttxt == "—") ? na : color.new(#1565c0, 75), text_font_family = font.family_monospace)

// Warnung bei falschem Timeframe
var table warn = table.new(position.bottom_right, 1, 1)
if barstate.islast
    table.cell(warn, 0, 0, timeframe.period != "1D" ? "⚠ Bitte auf den Tages-Chart (1D) anwenden" : "", text_color = color.white, bgcolor = timeframe.period != "1D" ? color.new(color.red, 10) : na)
